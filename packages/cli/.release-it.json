{
  "$schema": "https://unpkg.com/release-it@20/schema/release-it.json",
  "git": {
    "commitMessage": "chore(release): v${version}",
    "tagName": "v${version}",
    "requireCleanWorkingDir": true,
    "requireUpstream": true
  },
  "npm": {
    "publish": true
  },
  "hooks": {
    "before:init": [
      "pnpm --dir ../.. lint",
      "pnpm --dir ../.. typecheck",
      "pnpm --dir ../.. test"
    ]
  }
}
