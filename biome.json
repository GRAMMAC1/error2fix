{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": [
      "dist",
      "**/dist",
      ".rslib",
      "**/.rslib",
      "node_modules",
      "benchmarks/failures/**/compressed.md",
      "benchmarks/failures/**/debug.json"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "linter": {
    "rules": {
      "style": {
        "useTemplate": "info",
        "noNonNullAssertion": "off"
      }
    }
  }
}
