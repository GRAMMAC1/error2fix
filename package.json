{
  "name": "error2fix-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.2",
  "description": "Post-failure terminal diagnosis for developers.",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "check": "biome check .",
    "dev": "pnpm --filter error2fix dev",
    "format": "biome format --write .",
    "inspect:log": "node --import tsx scripts/inspect-log-pipeline.ts",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "mcp:dev": "pnpm --filter @error2fix/mcp dev",
    "mcp:start": "pnpm --filter @error2fix/mcp start",
    "prepare": "simple-git-hooks",
    "release:cli": "pnpm --dir packages/cli release",
    "release:mcp": "pnpm --dir packages/mcp release",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,json,md,yaml,yml}": "biome check --write --no-errors-on-unmatched"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.0.0",
    "execa": "^9.6.0",
    "globals": "^16.4.0",
    "lint-staged": "^15.5.2",
    "release-it": "^20.0.0",
    "simple-git-hooks": "^2.13.1",
    "tsup": "^8.3.6",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
